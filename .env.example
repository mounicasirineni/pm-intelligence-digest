### App
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000

### Storage
DATABASE_PATH=data/digest.sqlite3

### Sources
# Copy `config/sources.example.json` to `config/sources.json` and point here if you want.
SOURCES_CONFIG_PATH=config/sources.json
LOOKBACK_HOURS=24
DIGEST_SCHEDULE_HOUR=7
DIGEST_SCHEDULE_MINUTE=0
DIGEST_TIMEZONE=Asia/Kolkata

### Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

